# MongoDB — Solo necesaria para producción o "pnpm dev"
# "pnpm mock" inicia una base en memoria automáticamente (no requiere esta variable)
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/compra-bar

# JWT — Siempre requerida (incluso en mock, el código la exige al arrancar)
JWT_SECRET=una-clave-secreta-muy-segura

# Cloudinary — Opcional, para futura subida de imágenes (aún no implementado)
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=tu-api-key
# CLOUDINARY_API_SECRET=tu-api-secret
